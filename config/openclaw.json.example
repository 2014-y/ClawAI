{
  "_comment": "AI-v24.13.0 开源版 - 配置模板",
  "_comment2": "复制为 openclaw.json 并填入你的 API Key",
  "meta": {
    "version": "2026.6.11",
    "template": true
  },
  "env": {
    "shellEnv": {
      "enabled": true
    }
  },
  "logging": {
    "level": "info",
    "redactSensitive": "tools",
    "consoleLevel": "info",
    "consoleStyle": "compact"
  },
  "models": {
    "providers": {
      "agnes-ai": {
        "baseUrl": "https://apihub.agnes-ai.com/v1",
        "apiKey": "<YOUR_AGNES_API_KEY>",
        "api": "openai-completions",
        "models": [
          {
            "id": "agnes-2.0-flash",
            "name": "Agnes 2.0 Flash",
            "contextWindow": 524288,
            "maxTokens": 65536,
            "input": ["text", "image"]
          },
          {
            "id": "agnes-1.5-flash",
            "name": "Agnes 1.5 Flash",
            "contextWindow": 131072,
            "maxTokens": 8192,
            "input": ["text", "image"]
          }
        ]
      },
      "ollama": {
        "baseUrl": "http://localhost:11434/v1",
        "api": "openai-completions",
        "models": [
          {
            "id": "gemma4:latest",
            "name": "Gemma4 Latest",
            "contextWindow": 32768,
            "maxTokens": 4096,
            "input": ["text"]
          }
        ]
      }
    }
  },
  "agents": {
    "defaults": {
      "model": {
        "primary": "agnes-ai/agnes-2.0-flash",
        "fallbacks": [
          "agnes-ai/agnes-1.5-flash",
          "ollama/gemma4:latest"
        ]
      },
      "contextPruning": ["cache-ttl", "3m"],
      "compaction": {
        "reserveTokensFloor": 16000
      },
      "heartbeat": {
        "every": "30m"
      },
      "imageModel": {
        "primary": "agnes-ai-image/agnes-image-2.0-flash"
      },
      "memorySearch": {
        "provider": "ollama/nomic-embed-text"
      }
    }
  },
  "plugins": {
    "allow": [
      "dual-model-trainer",
      "memory-core",
      "health-check",
      "voice-call",
      "browser",
      "ollama",
      "google"
    ],
    "load": {
      "paths": ["./plugins"]
    }
  },
  "mcp": {
    "servers": {
      "computer-use": {
        "command": "open-computer-use",
        "args": ["mcp"]
      }
    }
  },
  "channels": {
    "enabled": ["wechat", "whatsapp"],
    "disabled": ["telegram", "discord", "imessage"]
  }
}

