# .gitignore

# 敏感配置
openclaw.json
*.json.bak
*.json.backup*
*.clobbered*
*.rejected*
*.last-good

# 认证/凭证
credentials/**
agents/*/agent/auth-profiles.json.sqlite*
agents/*/agent/openclaw-agent.sqlite*
plugins/workboard/workboard.sqlite*

# API Keys（覆盖配置模板中的占位符）
**/*.key
**/*.crt
**/*.pem
config/ca.key
config/yuanhai.key

# 会话数据
agents/*/sessions/*.jsonl
agents/*/sessions/*.jsonl.*
agents/*/sessions/*.trajectory*
agents/*/sessions/*.trajectory-path.json
agents/*/sessions/sessions.json
agents/*/sessions/.usage-cost-cache.json

# 日志文件
logs/**
*.log
gateway-error.log
gateway-output.log

# 临时文件
*.tmp
*.temp
*~
.DS_Store
Thumbs.db

# Node.js
node_modules/
*.tgz

# Python
__pycache__/
*.pyc
*.pyo
*.egg-info/
.venv/
venv/

# 媒体输出
media-output/

# 训练数据
training-data/**
glm4_finetune/

# NVM 目录
nvm/

# 微信账号数据
openclaw-weixin/accounts/
openclaw-weixin/accounts.json

# 状态文件
state/
feishu_sessions/

# 编辑器
.vscode/
.idea/
*.swp
*.swo

# 压缩包
*.zip
*.rar
*.7z
*.tar.gz
